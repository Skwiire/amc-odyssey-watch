<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ethan.amc-odyssey-watch</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/ethanbaer/amc-odyssey-watch/amc_odyssey_watch.py</string>
        <string>--once</string>
    </array>

    <!-- Run every 5 minutes, and once at load. -->
    <key>StartInterval</key>
    <integer>300</integer>
    <key>RunAtLoad</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/Users/ethanbaer/amc-odyssey-watch</string>

    <key>StandardOutPath</key>
    <string>/Users/ethanbaer/amc-odyssey-watch/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/ethanbaer/amc-odyssey-watch/launchd.err.log</string>

    <!-- Only run while you're logged in (needed for notifications/sound). -->
    <key>LimitLoadToSessionType</key>
    <string>Aqua</string>
</dict>
</plist>
